# Server Configuration
PORT=4000
HOST=localhost

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-change-this

# File Upload Limits
MAX_FILE_SIZE=52428800
UPLOAD_DIR=./uploads
USERS_FILE=./users/users-info.json

# Allowed File Types (comma-separated MIME types)
ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,image/svg+xml,application/pdf,text/plain,application/json,application/javascript,text/css,application/zip,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,video/mp4,video/webm,audio/mpeg,audio/wav

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
