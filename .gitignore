# Dependencies
node_modules/

# Environment Variables
.env
.env.local
.env.*.local

# Build & Output Directories
dist/
build/

# IDE & Editor Files
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
logs/
*.log
npm-debug.log*

# Runtime Data
.pids/
*.pid
*.seed
*.pid.lock

# OS Generated Files
Thumbs.db
.DS_Store

# Optional: If you generate any temporary files
tmp/
temp/

# Uploaded files (keep directory structure but ignore content)
uploads/*
!uploads/.gitkeep

# User data (ignore actual user data)
users/*.json
!users/.gitkeep
